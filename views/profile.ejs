<%- include('partials/header') %>

<div class="profile-page">

  <!-- Cover + Avatar -->
  <div class="profile-cover">
    <div class="cover-gradient"></div>
  </div>

  <div class="profile-body">

    <!-- Left Column: Info Card -->
    <div class="profile-sidebar">
      <div class="profile-card">
        <div class="profile-av-wrap">
          <div class="profile-av"><%= profile.username.charAt(0).toUpperCase() %></div>
          <% if(profile.isVerified){ %>
            <div class="pav-tick"><i class="fas fa-circle-check"></i></div>
          <% } %>
        </div>

        <h1 class="pname">
          <%= profile.username %>
          <% if(profile.isAdmin){ %><span class="admin-tag-lg">Admin</span><% } %>
        </h1>

        <% if(profile.isVerified){ %>
          <p class="pverified"><i class="fas fa-circle-check"></i> Verified Reviewer</p>
        <% } %>

        <div class="pstats-grid">
          <div class="pstat">
            <span><%= reviewCount %></span>
            <small>Reviews</small>
          </div>
          <div class="pstat">
            <span><%= followerCount %></span>
            <small>Followers</small>
          </div>
          <div class="pstat">
            <span><%= followingCount %></span>
            <small>Following</small>
          </div>
        </div>

        <% if(!isOwnProfile && user){ %>
          <button id="followBtn"
            class="btn btn-full <%= isFollowing ? 'btn-ghost' : 'btn-red' %>"
            data-uid="<%= profile._id %>"
            onclick="profileFollow(this)">
            <i class="fas <%= isFollowing ? 'fa-user-check' : 'fa-user-plus' %>"></i>
            <span><%= isFollowing ? 'Following' : 'Follow' %></span>
          </button>
        <% } else if(!user){ %>
          <a href="/auth/login?redirect=/profile/<%= profile.username %>"
             class="btn btn-red btn-full">
            <i class="fas fa-user-plus"></i> Follow
          </a>
        <% } %>

        <div class="pmember">
          <i class="fas fa-calendar-alt"></i>
          Joined <%= new Date(profile.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'long'}) %>
        </div>
      </div>

      <!-- Followers preview -->
      <% if(profile.followers && profile.followers.length){ %>
      <div class="ppeople-card">
        <h3><i class="fas fa-users"></i> Followers</h3>
        <div class="ppeople-list">
          <% profile.followers.slice(0,8).forEach(f=>{ %>
            <a href="/profile/<%= f.username %>" class="ppeople-item" title="<%= f.username %>">
              <div class="pp-av"><%= f.username.charAt(0).toUpperCase() %></div>
              <span><%= f.username %></span>
              <% if(f.isVerified){ %><i class="fas fa-circle-check vtick"></i><% } %>
            </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Following preview -->
      <% if(profile.following && profile.following.length){ %>
      <div class="ppeople-card">
        <h3><i class="fas fa-user-friends"></i> Following</h3>
        <div class="ppeople-list">
          <% profile.following.slice(0,8).forEach(f=>{ %>
            <a href="/profile/<%= f.username %>" class="ppeople-item" title="<%= f.username %>">
              <div class="pp-av"><%= f.username.charAt(0).toUpperCase() %></div>
              <span><%= f.username %></span>
              <% if(f.isVerified){ %><i class="fas fa-circle-check vtick"></i><% } %>
            </a>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Right Column: Reviews Feed -->
    <div class="profile-feed">
      <div class="pfeed-header">
        <h2><i class="fas fa-star"></i> Reviews by <%= profile.username %></h2>
        <span class="cnt-badge"><%= reviewCount %></span>
      </div>

      <% if(!reviews.length){ %>
        <div class="pempty">
          <i class="fas fa-star"></i>
          <p>No reviews yet.</p>
          <% if(isOwnProfile){ %>
            <a href="/" class="btn btn-red">Browse Movies</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="pfeed-grid">
          <% reviews.forEach(r=>{ %>
            <% if(!r.movieId) return; %>
            <div class="pfeed-card">
              <a href="/movie/<%= r.movieId._id %>" class="pfeed-movie">
                <img src="<%= r.movieId.image %>" alt="<%= r.movieId.title %>"
                     onerror="this.onerror=null;this.src='/images/placeholder.svg'"/>
                <div class="pfeed-movie-info">
                  <strong><%= r.movieId.title %></strong>
                  <small><%= r.movieId.language %></small>
                </div>
              </a>
              <div class="pfeed-body">
                <div class="pfeed-stars">
                  <% for(let i=1;i<=5;i++){ %>
                    <i class="fas fa-star <%= i<=r.rating?'son':'soff'%>"></i>
                  <% } %>
                  <span class="rbadge"><%= r.rating %>/5</span>
                  <% if(r.pinned){ %>
                    <span class="pin-mini"><i class="fas fa-thumbtack"></i> Pinned</span>
                  <% } %>
                </div>
                <p class="pfeed-comment">"<%= r.comment %>"</p>
                <div class="pfeed-foot">
                  <span class="pfeed-date">
                    <i class="fas fa-clock"></i>
                    <%= new Date(r.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'}) %>
                  </span>
                  <span class="pfeed-likes">
                    <i class="fas fa-heart"></i> <%= r.likeCount||0 %>
                  </span>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
async function profileFollow(btn){
  const uid = btn.dataset.uid;
  try{
    const res  = await fetch('/api/follow/'+uid,{method:'POST'});
    const data = await res.json();
    if(data.success){
      btn.classList.toggle('btn-red', !data.following);
      btn.classList.toggle('btn-ghost', data.following);
      btn.querySelector('i').className = data.following?'fas fa-user-check':'fas fa-user-plus';
      btn.querySelector('span').textContent = data.following?'Following':'Follow';
      // update follower count
      const fcEl = document.querySelector('.pstat span');
      // find the followers stat
      document.querySelectorAll('.pstat').forEach(el=>{
        if(el.querySelector('small')?.textContent==='Followers'){
          const n=parseInt(el.querySelector('span').textContent)||0;
          el.querySelector('span').textContent = data.following?n+1:Math.max(0,n-1);
        }
      });
    }
  }catch(e){ console.error(e); }
}
</script>

<%- include('partials/footer') %>
