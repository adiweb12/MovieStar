<%- include('partials/header') %>

<!-- Followers/Following Modal -->
<div id="peopleModal" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <div class="modal-head">
      <h3 id="modalTitle">Followers</h3>
      <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="modalBody">
      <div class="modal-loading"><i class="fas fa-spinner fa-spin"></i></div>
    </div>
  </div>
</div>

<div class="profile-page">

  <!-- Cover -->
  <div class="profile-cover"><div class="cover-gradient"></div></div>

  <div class="profile-body">

    <!-- Left: Info Card -->
    <div class="profile-sidebar">
      <div class="profile-card">
        <div class="profile-av-wrap">
          <div class="profile-av"><%= profile.username.charAt(0).toUpperCase() %></div>
          <% if(profile.isVerified){ %><div class="pav-tick"><i class="fas fa-circle-check"></i></div><% } %>
        </div>

        <h1 class="pname">
          <%= profile.username %>
          <% if(profile.isAdmin){ %><span class="admin-tag-lg">Admin</span><% } %>
        </h1>
        <% if(profile.isVerified){ %>
          <p class="pverified"><i class="fas fa-circle-check"></i> Verified Reviewer</p>
        <% } %>

        <!-- Stats — clickable to open modal -->
        <div class="pstats-grid">
          <div class="pstat">
            <span><%= reviewCount %></span>
            <small>Reviews</small>
          </div>
          <div class="pstat pstat-click"
               onclick="openModal('followers','<%= profile._id %>','Followers')"
               title="View followers">
            <span id="followerCountEl"><%= followerCount %></span>
            <small>Followers <i class="fas fa-chevron-right pstat-arr"></i></small>
          </div>
          <div class="pstat pstat-click"
               onclick="openModal('following','<%= profile._id %>','Following')"
               title="View following">
            <span id="followingCountEl"><%= followingCount %></span>
            <small>Following <i class="fas fa-chevron-right pstat-arr"></i></small>
          </div>
        </div>

        <!-- Follow / Unfollow -->
        <% if(!isOwnProfile && user){ %>
          <button id="followBtn"
            class="btn btn-full <%= isFollowing ? 'btn-ghost following' : 'btn-red' %>"
            data-uid="<%= profile._id %>">
            <i class="fas <%= isFollowing ? 'fa-user-check' : 'fa-user-plus' %>"></i>
            <span><%= isFollowing ? 'Following' : 'Follow' %></span>
          </button>
        <% } else if(!user){ %>
          <a href="/auth/login?redirect=/profile/<%= profile.username %>"
             class="btn btn-red btn-full">
            <i class="fas fa-user-plus"></i> Follow
          </a>
        <% } %>

        <div class="pmember">
          <i class="fas fa-calendar-alt"></i>
          Joined <%= new Date(profile.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'long'}) %>
        </div>

        <!-- Admin panel button (own profile + admin only) -->
        <% if(profile.isAdmin && isOwnProfile){ %>
        <div class="admin-panel-btn-wrap">
          <a href="/admin" class="btn btn-admin-panel btn-full">
            <i class="fas fa-shield-halved"></i> Open Admin Panel
          </a>
          <p class="admin-panel-note"><i class="fas fa-lock"></i> Admin access only</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Right: Reviews Feed -->
    <div class="profile-feed">
      <div class="pfeed-header">
        <h2><i class="fas fa-star"></i> Reviews by <%= profile.username %></h2>
        <span class="cnt-badge"><%= reviewCount %></span>
      </div>

      <% if(!reviews.length){ %>
        <div class="pempty">
          <i class="fas fa-star"></i>
          <p>No reviews yet.</p>
          <% if(isOwnProfile){ %>
            <a href="/" class="btn btn-red">Browse Movies</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="pfeed-grid">
          <% reviews.forEach(r=>{ %>
            <% if(!r.movieId) return; %>
            <div class="pfeed-card">
              <a href="/movie/<%= r.movieId._id %>" class="pfeed-movie">
                <img src="<%= r.movieId.image %>" alt="<%= r.movieId.title %>"
                     onerror="this.onerror=null;this.src='/images/placeholder.svg'"/>
                <div class="pfeed-movie-info">
                  <strong><%= r.movieId.title %></strong>
                  <small><%= r.movieId.language %></small>
                </div>
              </a>
              <div class="pfeed-body">
                <div class="pfeed-stars">
                  <% for(let i=1;i<=5;i++){ %>
                    <i class="fas fa-star <%= i<=r.rating?'son':'soff' %>"></i>
                  <% } %>
                  <span class="rbadge"><%= r.rating %>/5</span>
                  <% if(r.pinned){ %><span class="pin-mini"><i class="fas fa-thumbtack"></i> Pinned</span><% } %>
                </div>
                <p class="pfeed-comment">"<%= r.comment %>"</p>
                <div class="pfeed-foot">
                  <span class="pfeed-date">
                    <i class="fas fa-clock"></i>
                    <%= new Date(r.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'}) %>
                  </span>
                  <span class="pfeed-likes"><i class="fas fa-heart"></i> <%= r.likeCount||0 %></span>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
// ── Attach follow button ───────────────────────────
const followBtn = document.getElementById('followBtn');
if (followBtn) {
  followBtn.addEventListener('click', async () => {
    const uid = followBtn.dataset.uid;
    followBtn.disabled = true;
    try {
      const res  = await fetch('/api/follow/' + uid, { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        const isNowFollowing = data.following;
        followBtn.classList.toggle('btn-red',   !isNowFollowing);
        followBtn.classList.toggle('btn-ghost',   isNowFollowing);
        followBtn.classList.toggle('following',   isNowFollowing);
        followBtn.querySelector('i').className = isNowFollowing ? 'fas fa-user-check' : 'fas fa-user-plus';
        followBtn.querySelector('span').textContent = isNowFollowing ? 'Following' : 'Follow';
        // Update count with real value from server
        const el = document.getElementById('followerCountEl');
        if (el) el.textContent = data.followers;
      } else {
        alert(data.message || 'Something went wrong');
      }
    } catch(e) { console.error(e); }
    followBtn.disabled = false;
  });
}

// ── Followers / Following Modal ────────────────────
async function openModal(type, userId, title) {
  const modal = document.getElementById('peopleModal');
  const body  = document.getElementById('modalBody');
  const tEl   = document.getElementById('modalTitle');
  tEl.textContent = title;
  body.innerHTML  = '<div class="modal-loading"><i class="fas fa-spinner fa-spin"></i></div>';
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';

  try {
    const res  = await fetch('/api/people/' + userId + '?type=' + type);
    const data = await res.json();
    if (!data.users || !data.users.length) {
      body.innerHTML = '<div class="modal-empty"><i class="fas fa-user-slash"></i><p>No ' + title.toLowerCase() + ' yet.</p></div>';
      return;
    }
    body.innerHTML = data.users.map(u => `
      <a href="/profile/${u.username}" class="modal-user" onclick="closeModal()">
        <div class="mu-av">${u.username.charAt(0).toUpperCase()}</div>
        <div class="mu-info">
          <strong>${u.username}${u.isVerified ? ' <i class="fas fa-circle-check vtick"></i>' : ''}${u.isAdmin ? ' <span class="admin-tag">Admin</span>' : ''}</strong>
          <small>${u.followers ? u.followers.length : 0} followers</small>
        </div>
        <i class="fas fa-chevron-right mu-arr"></i>
      </a>`).join('');
  } catch(e) {
    body.innerHTML = '<div class="modal-empty"><p>Failed to load. Try again.</p></div>';
  }
}

function closeModal() {
  document.getElementById('peopleModal').style.display = 'none';
  document.body.style.overflow = '';
}
document.getElementById('peopleModal').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

<%- include('partials/footer') %>
