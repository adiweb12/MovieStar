<%
// Auto-proxy Wikimedia images through our server to add required Referer header
// Cloudinary URLs (res.cloudinary.com) and local images work directly
function imgSrc(url) {
  if (!url) return '/images/placeholder.svg';
  if (url.startsWith('/')) return url;  // local file
  if (url.includes('cloudinary.com')) return url;  // Cloudinary - direct
  if (url.includes('wikimedia.org') || url.includes('wikipedia.org')) {
    return '/img-proxy?url=' + encodeURIComponent(url);
  }
  return url;  // other external URLs - direct
}
const posterSrc = imgSrc(movie.image);
%>
<a href="/movie/<%= movie._id %>" class="mcard">
  <div class="mcard-img">
    <img src="<%= posterSrc %>" alt="<%= movie.title %>" loading="lazy"
         onerror="this.onerror=null;this.src='/images/placeholder.svg'"/>
    <div class="mcard-shine"></div>
    <div class="mcard-ov">
      <% if (movie.type==='upcoming')  { %><span class="badge bpurple">Coming Soon</span><% } %>
      <% if (movie.type==='trending')  { %><span class="badge bred">🔥 Trending</span><% } %>
      <div class="play-btn"><i class="fas fa-play"></i></div>
    </div>
    <% if (movie.averageRating>0) { %>
      <div class="card-star-badge"><i class="fas fa-star"></i> <%= movie.averageRating %></div>
    <% } %>
  </div>
  <div class="mcard-body">
    <p class="mcard-title"><%= movie.title %></p>
    <div class="mcard-meta">
      <span class="ltag"><%= movie.language %></span>
      <% if (movie.releaseDate) { %><span><%= new Date(movie.releaseDate).getFullYear() %></span><% } %>
    </div>
  </div>
</a>
