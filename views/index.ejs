<%- include('partials/header') %>

<% if (announcement) { %>
<div class="announce-bar">
  <i class="fas fa-bullhorn"></i>
  <span><%= announcement.message %></span>
  <button onclick="this.parentElement.style.display='none'" class="announce-close">&times;</button>
</div>
<% } %>

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="hero-pill"><i class="fas fa-film"></i> South Indian Cinema Hub</div>
    <h1>Discover.<br/><span>Rate.</span> Review.</h1>
    <p>Explore Malayalam, Tamil, Telugu & Kannada films — rated by fans.</p>
    <div class="hero-btns">
      <a href="#trending"  class="btn btn-red btn-lg"><i class="fas fa-fire"></i> Trending</a>
      <a href="#upcoming"  class="btn btn-ghost btn-lg"><i class="fas fa-calendar"></i> Coming Soon</a>
    </div>
  </div>
  <div class="hero-stats">
    <div class="hstat"><span>50+</span><small>Movies</small></div>
    <div class="hstat"><span>5</span><small>Languages</small></div>
    <div class="hstat"><span>★</span><small>Fan Reviews</small></div>
  </div>
</section>

<div class="filter-bar" id="filterBar">
  <div class="filter-inner">
    <button class="pill active" data-filter="all">All</button>
    <button class="pill" data-filter="trending">🔥 Trending</button>
    <button class="pill" data-filter="malayalam">Malayalam</button>
    <button class="pill" data-filter="tamil">Tamil</button>
    <button class="pill" data-filter="telugu">Telugu</button>
    <button class="pill" data-filter="kannada">Kannada</button>
    <button class="pill" data-filter="hindi">Hindi</button>
    <button class="pill" data-filter="upcoming">Upcoming</button>
  </div>
</div>

<% const shelf = (icon, label, items, id='') => { %>
<% if (items.length) { %>
<section class="shelf" <%= id ? `id="${id}"` : '' %>>
  <div class="shelf-hd">
    <h2><span><%= icon %></span> <%= label %></h2>
    <a class="see-all" href="#">See all <i class="fas fa-chevron-right"></i></a>
  </div>
  <div class="shelf-row">
    <% items.forEach(m => { %><%- include('partials/movieCard',{movie:m}) %><% }) %>
  </div>
</section>
<% } %>
<% } %>

<%- shelf('🔥','Trending Now',    trending,          'trending') %>
<%- shelf('🇮🇳','Malayalam',      malayalam,          'malayalam-sec') %>
<%- shelf('🎵','Tamil',           tamil,              'tamil-sec') %>
<%- shelf('🎬','Telugu',          telugu,             'telugu-sec') %>
<%- shelf('🦁','Kannada',         kannada,            'kannada-sec') %>
<%- shelf('🎞️','Recently Released',recentlyReleased,  '') %>
<%- shelf('🔮','Coming Soon',     upcoming,          'upcoming') %>

<%- include('partials/footer') %>
