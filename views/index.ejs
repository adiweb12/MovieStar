<%- include('partials/header') %>

<!-- ── Hero ── -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="hero-badge"><i class="fas fa-film"></i> South Indian Cinema Hub</div>
    <h1>Discover.<br /><span>Rate.</span> Review.</h1>
    <p>Explore the best of Malayalam, Tamil, Telugu &amp; Kannada films — rated by fans like you.</p>
    <div class="hero-btns">
      <a href="#trending"   class="btn btn-red btn-lg"><i class="fas fa-fire"></i> Trending Now</a>
      <a href="#upcoming"   class="btn btn-ghost btn-lg"><i class="fas fa-calendar"></i> Coming Soon</a>
    </div>
  </div>
  <div class="hero-stats">
    <div class="stat"><span id="movieCountStat">50</span><small>Movies</small></div>
    <div class="stat"><span>5</span><small>Languages</small></div>
    <div class="stat"><span>★</span><small>Fan Reviews</small></div>
  </div>
</section>

<!-- ── Filter Bar ── -->
<div class="filter-bar" id="filterBar">
  <div class="filter-inner">
    <button class="pill active" data-filter="all">All</button>
    <button class="pill" data-filter="trending">🔥 Trending</button>
    <button class="pill" data-filter="malayalam">Malayalam</button>
    <button class="pill" data-filter="tamil">Tamil</button>
    <button class="pill" data-filter="telugu">Telugu</button>
    <button class="pill" data-filter="kannada">Kannada</button>
    <button class="pill" data-filter="hindi">Hindi</button>
    <button class="pill" data-filter="upcoming">Upcoming</button>
  </div>
</div>

<!-- ── Trending ── -->
<% if (trending.length) { %>
<section class="shelf" id="trending" data-type="trending">
  <div class="shelf-header">
    <h2><span class="icon">🔥</span> Trending Now</h2>
    <a class="see-all" href="#">See all <i class="fas fa-chevron-right"></i></a>
  </div>
  <div class="shelf-row">
    <% trending.forEach(m => { %><%- include('partials/movieCard', { movie: m }) %><% }) %>
  </div>
</section>
<% } %>

<!-- ── Malayalam ── -->
<% if (malayalam.length) { %>
<section class="shelf" id="malayalam-section" data-lang="malayalam">
  <div class="shelf-header">
